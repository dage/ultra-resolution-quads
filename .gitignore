# Ignore everything under datasets/*/ except configs and per-dataset renderers
datasets/*/*/
!datasets/*/*.json
!datasets/*/render.py
!datasets/*/*.md
datasets/genzoom_exp_*/
datasets/*/temp_*.png
datasets/*/temp_*.jpg
datasets/*/temp_*.jpeg

# General ignores
**/__pycache__/
artifacts/
GEMINI.md
datasets/.DS_Store
.DS_Store
.env
.numba_cache
datasets/*/tiles.json
